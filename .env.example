# Access token for API authentication (optional)
ACCESS_TOKEN=

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/openclaw

# Server port (default: 3002)
PORT=3002

# Google OAuth (optional - enables Google login)
GOOGLE_CLIENT_ID=
JWT_SECRET=

# Frontend Google OAuth (must match GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=
